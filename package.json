{
  "name": "temp_init",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "prebuild": "echo \"export const BUILD_HASH = '$(git rev-parse --short HEAD)';\" > src/buildInfo.ts",
    "postinstall": "if [ ! -f src/buildInfo.ts ]; then npm run prebuild; fi",
    "dev": "next dev",
    "build": "NEXT_PUBLIC_BUILD_HASH=$(git rev-parse --short HEAD) next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "nanoid": "^5.1.11",
    "next": "16.2.4",
    "nodemailer": "^8.0.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "swr": "^2.4.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
